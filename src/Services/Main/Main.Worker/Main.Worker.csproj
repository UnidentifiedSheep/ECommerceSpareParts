<Project Sdk="Microsoft.NET.Sdk.Worker">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <UserSecretsId>dotnet-Main.Worker-ecb3b657-acdf-477a-96f2-2565685d4040</UserSecretsId>
        <DockerDefaultTargetOS>Linux</DockerDefaultTargetOS>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.9" />
    </ItemGroup>

    <ItemGroup>
        <Content Include="..\..\..\..\.dockerignore">
          <Link>.dockerignore</Link>
        </Content>
        <Content Include="..\Main.Entities\Localization\**\*">
            <Link>Localization\%(RecursiveDir)%(Filename)%(Extension)</Link>
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
            <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
        </Content>
        <Content Include="..\..\..\..\configs\**\*">
            <Link>configs\%(RecursiveDir)%(Filename)%(Extension)</Link>
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
            <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
        </Content>
        <Content Include="..\..\Application.Common\Localization\**\*">
            <Link>Localization\%(RecursiveDir)%(Filename)%(Extension)</Link>
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
            <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
        </Content>
    </ItemGroup>

    <ItemGroup>
      <ProjectReference Include="..\..\..\Infrastructure\Security\Security.csproj" />
      <ProjectReference Include="..\..\Api.Common\Api.Common.csproj" />
      <ProjectReference Include="..\Main.Api\Main.Api.csproj" />
      <ProjectReference Include="..\Main.Cache\Main.Cache.csproj" />
      <ProjectReference Include="..\Main.Persistence\Main.Persistence.csproj" />
    </ItemGroup>
</Project>
