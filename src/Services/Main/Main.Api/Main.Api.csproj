<Project Sdk="Microsoft.NET.Sdk.Web">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ServerGarbageCollection>true</ServerGarbageCollection>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <DockerDefaultTargetOS>Linux</DockerDefaultTargetOS>
        <LangVersion>14</LangVersion>
        <PreserveCompilationContext>true</PreserveCompilationContext>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Carter" Version="10.0.0"/>
        <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" Version="10.0.9" />
        <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="10.0.9" />
        <PackageReference Include="OpenTelemetry.Exporter.Prometheus.AspNetCore" Version="1.14.0-beta.1"/>
        <PackageReference Include="OpenTelemetry.Extensions.Hosting" Version="1.16.0" />
        <PackageReference Include="OpenTelemetry.Instrumentation.AspNetCore" Version="1.16.0" />
        <PackageReference Include="OpenTelemetry.Instrumentation.Process" Version="1.14.0-beta.2"/>
        <PackageReference Include="OpenTelemetry.Instrumentation.Runtime" Version="1.15.1" />
        <PackageReference Include="prometheus-net.AspNetCore" Version="8.2.1"/>
        <PackageReference Include="Serilog.Sinks.Loki" Version="4.0.0-beta3"/>
        <PackageReference Include="Swashbuckle.AspNetCore.Swagger" Version="10.0.1"/>
        <PackageReference Include="Swashbuckle.AspNetCore.SwaggerGen" Version="10.0.1"/>
        <PackageReference Include="Swashbuckle.AspNetCore.SwaggerUI" Version="10.0.1"/>
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\..\Infrastructure\Cache\Cache.csproj"/>
        <ProjectReference Include="..\..\..\Infrastructure\Common\Common.csproj"/>
        <ProjectReference Include="..\..\..\Infrastructure\Integrations\ExchangeRate\ExchangeRate.csproj"/>
        <ProjectReference Include="..\..\..\Infrastructure\Mailing\Mail\Mail.csproj" />
        <ProjectReference Include="..\..\..\Infrastructure\RabbitMq\RabbitMq.csproj"/>
        <ProjectReference Include="..\..\..\Infrastructure\S3\S3.csproj"/>
        <ProjectReference Include="..\..\..\Infrastructure\Security\Security.csproj"/>
        <ProjectReference Include="..\..\Api.Common\Api.Common.csproj"/>
        <ProjectReference Include="..\..\Application.Common\Application.Common.csproj"/>
        <ProjectReference Include="..\Main.Application\Main.Application.csproj"/>
        <ProjectReference Include="..\Main.Cache\Main.Cache.csproj"/>
        <ProjectReference Include="..\Main.Persistence\Main.Persistence.csproj"/>
    </ItemGroup>

    <ItemGroup>
        <Content Include="..\..\..\..\.dockerignore">
          <Link>.dockerignore</Link>
        </Content>
        <Content Include="..\Main.Entities\Localization\**\*">
            <Link>Localization\%(RecursiveDir)%(Filename)%(Extension)</Link>
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
            <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
        </Content>
        <Content Include="..\..\Application.Common\Localization\**\*">
            <Link>Localization\%(RecursiveDir)%(Filename)%(Extension)</Link>
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
            <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
        </Content>
        <Content Include="..\..\..\..\configs\**\*">
            <Link>configs\%(RecursiveDir)%(Filename)%(Extension)</Link>
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
            <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
        </Content>
    </ItemGroup>

    <Target Name="AddEmailTemplatesToPublish" BeforeTargets="ComputeFilesToPublish">
        <ItemGroup>
            <EmailTemplate Include="..\..\..\Infrastructure\Mailing\EmailTemplates\**\*.cshtml" />
            <ResolvedFileToPublish Include="@(EmailTemplate)">
                <RelativePath>Templates\Emails\%(EmailTemplate.RecursiveDir)%(EmailTemplate.Filename)%(EmailTemplate.Extension)</RelativePath>
                <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
            </ResolvedFileToPublish>
        </ItemGroup>
    </Target>

</Project>
