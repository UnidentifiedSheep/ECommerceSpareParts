<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <LangVersion>14</LangVersion>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\..\Core\Exceptions\Exceptions.csproj"/>
        <ProjectReference Include="..\Search.Entities\Search.Entities.csproj"/>
        <ProjectReference Include="..\Search.Enums\Search.Enums.csproj"/>
    </ItemGroup>
    
    <ItemGroup>
        <Content Include="..\..\Application.Common\Localization\**\*">
            <Link>Localization\%(RecursiveDir)%(Filename)%(Extension)</Link>
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
            <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
        </Content>
    </ItemGroup>

</Project>
