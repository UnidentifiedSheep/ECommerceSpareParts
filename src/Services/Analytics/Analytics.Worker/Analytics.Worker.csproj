<Project Sdk="Microsoft.NET.Sdk.Worker">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <UserSecretsId>dotnet-Analytics.Worker-04705b45-eb58-4513-b3e0-3603db44821f</UserSecretsId>
        <DockerDefaultTargetOS>Linux</DockerDefaultTargetOS>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="MassTransit.Abstractions" Version="8.5.8" />
        <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.3"/>
    </ItemGroup>

    <ItemGroup>
      <ProjectReference Include="..\..\..\Core\Contracts\Contracts.csproj" />
      <ProjectReference Include="..\..\..\Infrastructure\RabbitMq\RabbitMq.csproj" />
      <ProjectReference Include="..\..\..\Infrastructure\Redis\Redis.csproj" />
      <ProjectReference Include="..\..\..\Infrastructure\Security\Security.csproj" />
      <ProjectReference Include="..\..\Api.Common\Api.Common.csproj" />
      <ProjectReference Include="..\Analytics.Application\Analytics.Application.csproj" />
      <ProjectReference Include="..\Analytics.Persistence\Analytics.Persistence.csproj" />
    </ItemGroup>
    
    <ItemGroup>
        <Content Include="..\..\..\..\.dockerignore">
          <Link>.dockerignore</Link>
        </Content>
        <Content Include="..\Analytics.Abstractions\Localization\**\*">
            <Link>Localization\%(RecursiveDir)%(Filename)%(Extension)</Link>
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
            <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
        </Content>
    </ItemGroup>
</Project>
