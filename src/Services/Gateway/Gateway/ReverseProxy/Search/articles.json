{
  "ReverseProxy": {
    "Routes": {
      "get-article-by-id": {
        "ClusterId": "search-cluster",
        "Match": {
          "Path": "/search/articles/{articleId}",
          "Methods": [
            "GET"
          ]
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/search"
          }
        ]
      },
      "search-articles": {
        "ClusterId": "search-cluster",
        "Match": {
          "Path": "/search/articles",
          "Methods": [
            "GET"
          ]
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/search"
          }
        ]
      }
    }
  }
}