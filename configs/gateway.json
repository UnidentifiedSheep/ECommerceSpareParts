{
  "ReverseProxy": {
    "Routes": {
      "route-main-internal-deny": {
        "ClusterId": "blackhole-cluster",
        "Order": -100,
        "Match": {
          "Path": "/main/internal/{**catch-all}"
        },
        "AuthorizationPolicy": "DenyAll"
      },
      "route-analytics-internal-deny": {
        "ClusterId": "blackhole-cluster",
        "Order": -100,
        "Match": {
          "Path": "/analytics/internal/{**catch-all}"
        },
        "AuthorizationPolicy": "DenyAll"
      },
      "route-search-internal-deny": {
        "ClusterId": "blackhole-cluster",
        "Order": -100,
        "Match": {
          "Path": "/search/internal/{**catch-all}"
        },
        "AuthorizationPolicy": "DenyAll"
      },
      "route-pricing-internal-deny": {
        "ClusterId": "blackhole-cluster",
        "Order": -100,
        "Match": {
          "Path": "/pricing/internal/{**catch-all}"
        },
        "AuthorizationPolicy": "DenyAll"
      },
      "route-api": {
        "ClusterId": "main-cluster",
        "Order": 0,
        "Match": {
          "Path": "/main/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/main"
          }
        ]
      },
      "route-analytics": {
        "ClusterId": "analytics-cluster",
        "Order": 0,
        "Match": {
          "Path": "/analytics/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/analytics"
          }
        ]
      },
      "route-search": {
        "ClusterId": "search-cluster",
        "Order": 0,
        "Match": {
          "Path": "/search/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/search"
          }
        ]
      },
      "route-pricing": {
        "ClusterId": "pricing-cluster",
        "Order": 0,
        "Match": {
          "Path": "/pricing/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/pricing"
          }
        ]
      }
    },
    "Clusters": {
      "blackhole-cluster": {
        "Destinations": {
          "blackhole": {
            "Address": "http://127.0.0.1:1/"
          }
        }
      },
      "main-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:30",
            "Timeout": "00:00:02",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        },
        "Destinations": {
          "main-api": {
            "Address": "http://main.api:8080/"
          }
        }
      },
      "analytics-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:30",
            "Timeout": "00:00:02",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        },
        "Destinations": {
          "analytics-api": {
            "Address": "http://analytics.api:8080/"
          }
        }
      },
      "search-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:30",
            "Timeout": "00:00:02",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        },
        "Destinations": {
          "search-api": {
            "Address": "http://search.api:8080/"
          }
        }
      },
      "pricing-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:30",
            "Timeout": "00:00:02",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        },
        "Destinations": {
          "pricing-api": {
            "Address": "http://pricing.api:8080/"
          }
        }
      }
    }
  }
}